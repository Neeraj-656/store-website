# ── Gateway ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Downstream service URLs ────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3000
CATALOG_SERVICE_URL=http://catalog-service:3001
ORDER_SERVICE_URL=http://order-service:3002
PAYMENT_SERVICE_URL=http://payment-service:3004
REVIEW_SERVICE_URL=http://review-service:3005
INVENTORY_SERVICE_URL=http://inventory-service:3006
VENDOR_SERVICE_URL=http://vendor-service:3007
PAYOUT_SERVICE_URL=http://payout-service:3008
ADMIN_SERVICE_URL=http://admin-service:3009

# ── Auth ───────────────────────────────────────────────────────────────────────
# RS256 public key fetched from the auth service at startup.
# AUTH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Internal service JWT signing (Issue 5 fix) ─────────────────────────────────
# Replace the static shared token with short-lived, asymmetrically signed JWTs.
# The GATEWAY holds the PRIVATE key and signs tokens.
# Each downstream SERVICE holds only the PUBLIC key and can only verify.
#
# Generate a new keypair:
#   node -e "
#     const { generateKeyPairSync } = require('crypto');
#     const { privateKey, publicKey } = generateKeyPairSync('ec', { namedCurve: 'P-256' });
#     console.log(privateKey.export({ type:'pkcs8', format:'pem' }));
#     console.log(publicKey.export({ type:'spki',  format:'pem' }));
#   "
#
# In production, store these in AWS Secrets Manager / HashiCorp Vault and inject
# via Kubernetes secrets — never commit them to the repository.
INTERNAL_SIGNING_KEY_PRIVATE=REPLACE_WITH_EC_PRIVATE_KEY_PEM

# Legacy fallback — only used while migrating to JWT-based internal auth.
# Remove once INTERNAL_SIGNING_KEY_PRIVATE/PUBLIC are deployed on all services.
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_SHARED_RANDOM_SECRET

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=20

# ── CORS ───────────────────────────────────────────────────────────────────────
# REQUIRED in production — list allowed origins comma-separated.
# Using * in production will cause a startup error (intentional safety guard).
CORS_ORIGINS=*

# ── Redis (required for distributed rate limiting) ─────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Request body size limit ────────────────────────────────────────────────────
BODY_LIMIT=1mb
