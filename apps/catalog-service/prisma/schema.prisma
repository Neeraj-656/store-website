datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

generator client {
  provider = "prisma-client-js"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

//
// --- VENDOR READ-MODEL ---
//

model VendorProfile {
  id        String    @id
  isActive  Boolean   @default(false)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
}

//
// --- CATEGORY HIERARCHY ---
//

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique

  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")

  products  Product[]
  createdAt DateTime   @default(now())

  @@index([parentId])
}

//
// --- PRODUCT CORE ---
//

model Product {
  id          String        @id @default(uuid())
  version     Int           @default(1)

  vendorId    String
  vendor      VendorProfile @relation(fields: [vendorId], references: [id])

  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])

  name        String
  description String        @db.Text

  status      ProductStatus @default(DRAFT)

  images      ProductImage[]
  variants    ProductVariant[]
  audits         ProductAudit[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  idempotencyKey String?

  @@unique([id, version], name: "id_version")

 @@unique([vendorId, idempotencyKey]) // Allows Postgres to enforce idempotency
  @@unique([id, vendorId])
  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
  
}

//
// --- IMAGES ---
//

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  url       String
  isPrimary Boolean  @default(false)
  position  Int
  altText   String?

  @@index([productId])
}

//
// --- VARIANTS ---
//

model ProductVariant {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  sku        String   @unique
  price      Decimal  @db.Decimal(12, 2)
  attributes Json     @default("{}")

  @@index([productId])
}

//
// --- IDEMPOTENCY (EVENT CONSUMPTION) ---
//

model ProcessedEvent {
  id            String   @id @default(uuid())
  eventId       String   @unique
  eventName     String
  correlationId String?
  processedAt   DateTime @default(now())

  @@index([eventName])

}
enum OutboxStatus {
  PENDING
  PROCESSING // 🚀 Added to prevent mid-flight double processing
  PUBLISHED
  FAILED
}

model OutboxEvent {
  id            String       @id @default(uuid())
  aggregateId   String?  
  type          String   
  payload       Json     
  status        OutboxStatus @default(PENDING)
  retryCount    Int          @default(0)
  nextAttemptAt DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime @updatedAt
  publishedAt   DateTime?

  @@index([status, nextAttemptAt]) 
  // 💡 PRO-TIP: In production, run this raw SQL in your migration:
  // CREATE INDEX idx_outbox_pending ON "OutboxEvent" ("nextAttemptAt", "createdAt") WHERE status = 'PENDING';
}
model ProductAudit {
  id          String   @id @default(uuid())
  productId   String
  vendorId    String
  changedBy   String   // e.g., "vendor_123" or "admin_456"
  oldStatus   String
  newStatus   String
  reason      String?  // e.g., "Policy violation: Invalid images"
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId, createdAt]) // Optimized for timeline queries
}


