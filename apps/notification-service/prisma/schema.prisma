
// This is your Prisma schema file
// prisma folder is at the root level (not inside src)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum NotificationType {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  FAILED
  RETRYING
}

enum NotificationCategory {
  ORDER_CONFIRMATION
  VENDOR_ORDER_ALERT
  REFUND_NOTIFICATION
  OTP_DELIVERY
  GENERAL
}

enum TemplateType {
  EMAIL
  SMS
  PUSH
}

// ─────────────────────────────────────────────
// NOTIFICATION LOG
// Stores every notification dispatched
// ─────────────────────────────────────────────

model Notification {
  id           String               @id @default(uuid())
  type         NotificationType
  category     NotificationCategory
  status       NotificationStatus   @default(PENDING)
  recipient    String               // email address, phone number, or device token
  subject      String?              // email subject
  body         String               // rendered content
  metadata     Json?                // extra data (orderId, vendorId, etc.)
  attempts     Int                  @default(0)
  maxAttempts  Int                  @default(3)
  error        String?              // last error message
  jobId        String?              // BullMQ job id
  sentAt       DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status])
  @@index([type])
  @@index([category])
  @@index([recipient])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// TEMPLATES
// Handlebars templates for each channel
// ─────────────────────────────────────────────

model Template {
  id        String       @id @default(uuid())
  name      String       @unique // e.g. "order_confirmation_email"
  type      TemplateType
  category  NotificationCategory
  subject   String?      // for email templates
  body      String       // Handlebars template string
  isActive  Boolean      @default(true)
  version   Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([name])
  @@index([type, category])
}

// ─────────────────────────────────────────────
// PUSH CONFIGS
// Per-user device token registry
// ─────────────────────────────────────────────

model PushConfig {
  id          String   @id @default(uuid())
  userId      String
  deviceToken String
  platform    String   // ios | android | web
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, deviceToken])
  @@index([userId])
}

// ─────────────────────────────────────────────
// OTP
// Short-lived OTPs with expiry tracking
// ─────────────────────────────────────────────

model OTP {
  id          String   @id @default(uuid())
  recipient   String   // phone or email
  code        String
  purpose     String   // login | verify | reset
  isUsed      Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([recipient, isUsed])
}
