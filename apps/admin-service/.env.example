# ─── Server ────────────────────────────────────────────────
PORT=3008
NODE_ENV=development

# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@pgbouncer:5432/adminDB"
DATABASE_CONNECTION_LIMIT=5
DATABASE_POOL_TIMEOUT=10

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_AUDIENCE=your_audience
JWT_ISSUER=auth-service

# ─── Internal service auth (Issue 5 fix) ──────────────────
# The admin service holds ONLY the PUBLIC key — it can verify but not mint tokens.
# Copy the public key output from the key generation step documented in
# api-gateway/.env.example.
INTERNAL_SIGNING_KEY_PUBLIC=REPLACE_WITH_EC_PUBLIC_KEY_PEM

# Legacy fallback (used only while migrating to JWT-based internal auth).
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_SHARED_RANDOM_SECRET

# ─── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=ecommerce_events

# ─── Outbox sweeper retention ──────────────────────────────
OUTBOX_RETENTION_DAYS=7
MSG_ID_RETENTION_DAYS=30

# ─── Downstream Service URLs (internal network) ────────────
VENDOR_SERVICE_URL=http://vendor-service:3005
CATALOG_SERVICE_URL=http://catalog-service:3002
ORDER_SERVICE_URL=http://order-service:3001
PAYMENT_SERVICE_URL=http://payment-service:3004
PAYOUT_SERVICE_URL=http://payout-service:3007
REVIEW_SERVICE_URL=http://review-service:3006
