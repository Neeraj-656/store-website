generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum PaymentStatus {
  INITIATED
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum RefundType {
  FULL
  PARTIAL
}

// ─── Models ────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  userId            String

  // Razorpay IDs
  razorpayOrderId   String?       @unique  // created during charge()
  razorpayPaymentId String?       @unique  // set after payment.captured webhook
  idempotencyKey    String        @unique

  status            PaymentStatus @default(INITIATED)
  amount            Int                            // in paise (₹1 = 100 paise)
  currency          String        @default("INR")

  providerResponse  Json?                          // raw Razorpay payload
  failureReason     String?

  refunds           Refund[]
  statusHistory     PaymentStatusHistory[]
  outboxEvents      PaymentOutboxEvent[]

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model Refund {
  id               String       @id @default(uuid())
  paymentId        String
  payment          Payment      @relation(fields: [paymentId], references: [id])

  type             RefundType
  amount           Int
  reason           String?
  idempotencyKey   String       @unique

  status           RefundStatus @default(PENDING)
  razorpayRefundId String?      @unique
  providerResponse Json?
  failureReason    String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([paymentId])
}

model PaymentStatusHistory {
  id         String         @id @default(uuid())
  paymentId  String
  payment    Payment        @relation(fields: [paymentId], references: [id])

  fromStatus PaymentStatus?
  toStatus   PaymentStatus
  reason     String?

  createdAt  DateTime       @default(now())

  @@index([paymentId])
}

model PaymentOutboxEvent {
  id          String   @id @default(uuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id])

  eventType   String
  payload     Json
  published   Boolean  @default(false)
  publishedAt DateTime?

  createdAt   DateTime @default(now())

  @@index([published])
  @@index([paymentId])
}
